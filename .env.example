# Resend API key — used by src/app/api/contact/route.ts to send contact-form emails.
# Get one at https://resend.com/api-keys
RESEND_API_KEY=

# Mailbox that receives contact-form submissions.
CONTACT_TO_EMAIL=

# Public site URL used to build robots.txt and sitemap.xml (src/app/robots.ts, src/app/sitemap.ts).
NEXT_PUBLIC_SITE_URL=https://www.ingelpower.com
